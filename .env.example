# docker-compose reads this file automatically. Copy to .env and set UID/GID
# to your host user so files written to ./captures and ./recordings by the
# container are owned by you, not root.
#
#   cp .env.example .env
#   printf 'UID=%s\nGID=%s\n' "$(id -u)" "$(id -g)" > .env
#
# Linux defaults are typically 1000:1000. macOS often 501:20. CI may need
# something else. If .env is missing, docker-compose falls back to 1000:1000.

UID=1000
GID=1000
